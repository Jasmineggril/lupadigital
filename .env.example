# ──────────────────────────────────────────────────────────────────────────────
# LUPA Digital — Variáveis de ambiente necessárias no Vercel
# Copie este arquivo para o painel do Vercel em: Settings → Environment Variables
# ──────────────────────────────────────────────────────────────────────────────

# ── IA (Backend) ──────────────────────────────────────────────────────────────
# Groq (gratuito em console.groq.com — 100k tokens/dia no free tier)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (fallback — necessita créditos em platform.openai.com)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini direto (alternativa gratuita — console.cloud.google.com)
# GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase (Backend — service role, NUNCA expor no frontend) ────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxx
# Alternativa ao SUPABASE_SECRET_KEY (mesmo valor):
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxx

# JWKS do Supabase para verificar JWT (encontrar em: Authentication → JWT Settings)
SUPABASE_JWKS_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co/auth/v1/.well-known/jwks.json

# ── Supabase (Frontend — chave anon, pública, pode ser exposta) ───────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxx

# ── CORS (opcional) ───────────────────────────────────────────────────────────
# Lista separada por vírgulas das origens permitidas em produção.
# Se vazio, qualquer origem é aceita (menos seguro, mas funcional).
# Exemplo: https://lupa-digital.vercel.app,https://lupadigital.com.br
ALLOWED_ORIGINS=https://lupa-digital.vercel.app

# ── Banco de dados (usado por migrations/scripts — não obrigatório em runtime) ─
# DATABASE_URL=postgresql://postgres.xxxx:senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# DIRECT_URL=postgresql://postgres.xxxx:senha@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# ── Configuração ──────────────────────────────────────────────────────────────
NODE_ENV=production
