{
  "buildCommand": "pnpm --filter @workspace/lupa-publica run build",
  "outputDirectory": "artifacts/lupa-publica/dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
