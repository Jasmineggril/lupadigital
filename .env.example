# Supabase configuration for local development
# Do not commit your actual secret keys to source control.

# Supabase project URL
VITE_SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_URL=https://<your-project>.supabase.co

# Public client key for browser use
VITE_SUPABASE_ANON_KEY=sb_publishable_<your-key>
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>

# Optional Supabase server-side / auth settings
SUPABASE_SECRET_KEY=sb_secret_<your-secret>
SUPABASE_JWKS_URL=https://<your-project>.supabase.co

# Postgres connection strings
# For runtime (use the IPv4-only pooler endpoint):
# DATABASE_URL="postgresql://postgres.<project>:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# For migrations (direct session-mode connection):
# DIRECT_URL="postgresql://postgres.<project>:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"
#
# NOTE: Supabase Preview / CI environments may not reach IPv6-only database hosts.
# Use the IPv4-only pooler host when setting DATABASE_URL for preview deployments.
