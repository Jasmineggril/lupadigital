{
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/lupa-publica run build",
  "outputDirectory": "artifacts/lupa-publica/dist/public",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
